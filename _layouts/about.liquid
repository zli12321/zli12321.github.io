---
layout: default
---
<div class="post">
  <header class="post-header post-header-compact">
    {% if page.profile and page.profile.image %}
      {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
      <div class="profile-avatar">
        {%
          include figure.liquid loading="eager" path=profile_image_path class="img-fluid rounded-circle" alt=page.profile.image
          cache_bust=true
        %}
      </div>
    {% endif %}
    <div class="header-text">
      <h1 class="post-title">
        {% if site.title == 'blank' %}
          <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
          {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>
      <p class="desc">{{ page.subtitle }}</p>
      <div class="contact-email">email: zli12321 [at] umd.edu</div>
    </div>

    {% if page.social %}
      {% assign s = site.data.socials %}
      <div class="contact-list">
        {% if s.cv_pdf %}<a href="{{ s.cv_pdf | relative_url }}" target="_blank" rel="noopener"><i class="ai ai-cv"></i> CV</a>{% endif %}
        {% if s.email %}<a href="mailto:{{ s.email }}"><i class="fa-solid fa-envelope"></i> Email</a>{% endif %}
        {% if s.scholar_userid %}<a href="https://scholar.google.com/citations?user={{ s.scholar_userid }}" target="_blank" rel="noopener"><i class="ai ai-google-scholar"></i> Google Scholar</a>{% endif %}
        {% if s.github_username %}<a href="https://github.com/{{ s.github_username }}" target="_blank" rel="noopener"><i class="fa-brands fa-github"></i> GitHub</a>{% endif %}
        {% if s.x_username %}<a href="https://twitter.com/{{ s.x_username }}" target="_blank" rel="noopener"><i class="fa-brands fa-x-twitter"></i> X (Twitter)</a>{% endif %}
        {% if s.linkedin_username %}<a href="https://www.linkedin.com/in/{{ s.linkedin_username }}" target="_blank" rel="noopener"><i class="fa-brands fa-linkedin"></i> LinkedIn</a>{% endif %}
      </div>
    {% endif %}
  </header>

  <article>
    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center_margin.liquid %}
      {% else %}
        {% include newsletter.liquid center=true %}
      {% endif %}
    {% endif %}
  </article>
</div>

<style>
  .post-header-compact {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .post-header-compact .profile-avatar {
    flex: 0 0 auto;
  }
  .post-header-compact .profile-avatar figure,
  .post-header-compact .profile-avatar picture {
    margin: 0;
    display: block;
  }
  .post-header-compact .profile-avatar img {
    width: 84px;
    height: 84px;
    object-fit: cover;
    border-radius: 50%;
  }
  .post-header-compact .header-text {
    flex: 1 1 320px;
    min-width: 0;
  }
  .post-header-compact .post-title {
    font-size: 2rem;
    margin-bottom: 0.2rem;
    line-height: 1.15;
  }
  .post-header-compact .desc {
    margin-bottom: 0;
    font-size: 0.95rem;
  }
  .post-header-compact .contact-email {
    font-size: 0.95rem;
    margin-top: 0.4rem;
    color: var(--global-text-color);
  }
  .post-header-compact .contact-list {
    flex: 0 0 auto;
    margin-left: auto;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.2rem;
  }
  .post-header-compact .contact-list a {
    color: var(--global-text-color);
    font-size: 0.95rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .post-header-compact .contact-list a:hover {
    color: var(--global-theme-color);
  }
  .post-header-compact .contact-list a i {
    width: 1.4em;
    text-align: center;
    margin-right: 0.45rem;
  }
  @media (max-width: 600px) {
    .post-header-compact .contact-list {
      margin-left: 0;
      width: 100%;
    }
  }
</style>
