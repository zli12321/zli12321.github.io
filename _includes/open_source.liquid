<style>
  .open-source-projects .os-card {
    background-color: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    border-radius: 10px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .open-source-projects .os-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
  }
  .open-source-projects .os-title {
    color: var(--global-text-color);
    font-size: 0.95rem;
    line-height: 1.3;
    text-decoration: none;
  }
  .open-source-projects .os-title:hover {
    color: var(--global-theme-color);
  }
  .open-source-projects .os-desc {
    color: var(--global-text-color-light);
    font-size: 0.85rem;
    margin-bottom: 0;
  }
  .open-source-projects .os-star {
    color: var(--global-theme-color);
    border: 1px solid var(--global-divider-color);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.8rem;
    white-space: nowrap;
  }
</style>

<div class="row open-source-projects">
  {% for project in site.data.projects %}
  <div class="col-12 col-md-6 mb-3">
    <div class="os-card h-100">
      <div class="p-3">
        <div class="d-flex align-items-start justify-content-between mb-2">
          <a href="https://github.com/{{ project.github }}" target="_blank" rel="external noopener" class="os-title fw-bold font-weight-bold">
            <i class="fa-brands fa-github"></i> {{ project.name }}
          </a>
          <span class="os-star ms-2 ml-2" data-github-repo="{{ project.github }}">
            <i class="fa-solid fa-star"></i> &mdash;
          </span>
        </div>
        <p class="os-desc">{{ project.description }}</p>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

<script src="{{ '/assets/js/github_stars.js' | relative_url }}"></script>
